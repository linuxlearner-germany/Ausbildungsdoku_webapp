{
  "name": "berichtsheft_webapp",
  "version": "1.0.0",
  "description": "Ausbildungsdoku Webapp mit Rollen fuer Azubi, Ausbilder und Verwaltung",
  "main": "index.js",
  "scripts": {
    "prestart": "npm run build",
    "dev": "node scripts/dev.mjs",
    "dev:server": "node --watch index.js",
    "dev:client": "node scripts/build.mjs --watch",
    "infra:up": "docker compose -f docker-compose.dev-infra.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev-infra.yml down",
    "docker:local:up": "docker compose -f docker-compose.local.yml up -d --build",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml logs -f app",
    "docker:local:test": "docker compose -f docker-compose.local.yml run --rm app npm test",
    "build": "node scripts/build.mjs",
    "build:github-pages": "node scripts/build-github-pages.mjs",
    "start": "node index.js",
    "check": "node --check index.js && node --check app/config.js && node --check app/create-app.js && node --check app/create-dependencies.js && node --check app/create-db.js && node --check app/create-redis-client.js && node --check app/render-index-html.js",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:bootstrap": "node scripts/db-bootstrap.mjs",
    "admin:reset": "node scripts/admin-reset.mjs",
    "db:reset-test": "node scripts/db-reset-test.mjs",
    "test:unit": "node --test --test-concurrency=1 tests/*.test.mjs",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs tests/integration/*.test.mjs",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.mjs"
  },
  "keywords": [
    "berichtsheft",
    "ausbildung",
    "react",
    "express",
    "mssql"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "knex": "^3.2.9",
    "mssql": "^12.3.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "redis": "^5.12.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}

    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "xlsx": "^0.18.5"
  }

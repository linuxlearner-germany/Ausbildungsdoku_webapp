# App / Server
# Fuer Docker-first lokal normalerweise `production` und `HOST=0.0.0.0` beibehalten.
NODE_ENV=production
TZ=Europe/Berlin
HOST=0.0.0.0
PORT=3010
APP_PORT_MAPPING=3010:3010
MSSQL_LOCAL_PORT=1433
# Absolute URL der App, z. B. https://berichtsheft.example.com im Deployment.
APP_BASE_URL=
# Optionaler Basis-Pfad hinter Reverse Proxy, z. B. /ausbildungsdoku.
APP_BASE_PATH=
# Optional separate API-Basis-URL; leer laesst die App automatisch `${APP_BASE_PATH}/api` verwenden.
API_BASE_URL=
# Bei Reverse Proxy auf `true` oder passende Proxy-Anzahl setzen.
TRUST_PROXY=false
LOG_LEVEL=info
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000
REQUEST_BODY_LIMIT=15mb

# Session / Cookies
# Niemals echte Secrets committen. Beispielwerte hier nur lokal verwenden.
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_COOKIE_NAME=berichtsheft.sid
# Nur fuer echte Domains setzen, nicht fuer localhost.
SESSION_COOKIE_DOMAIN=
# Im lokalen Docker-Betrieb `false`, hinter HTTPS-Proxy spaeter `true`.
SESSION_SECURE=false
# Ueblich: `lax`, fuer Spezialfaelle `strict` oder `none` + `SESSION_SECURE=true`.
SESSION_SAME_SITE=lax
# Cookie-Lebensdauer im Browser.
SESSION_MAX_AGE_MS=28800000
# Redis-TTL fuer Sessions; normal gleich lang oder etwas laenger als das Cookie.
SESSION_TTL_SECONDS=28800

# Redis
# Entweder REDIS_URL komplett setzen oder Host/Port getrennt.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis speichert ausschliesslich Login-Sessions, nicht die Berichtsheftdaten.
REDIS_KEY_PREFIX=berichtsheft:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_MAX_RETRIES=4
REDIS_PING_INTERVAL_MS=30000

# MSSQL
# MSSQL ist die einzige Datenbank fuer Benutzer, Berichte, Noten, Freigaben und Audit-Logs.
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_DATABASE=ausbildungsdoku
MSSQL_TEST_DATABASE=ausbildungsdoku_test
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong(!)Password
# Lokal im Containerbetrieb meist `true`.
MSSQL_ENCRYPT=true
# Lokal mit Container-DB meist `true`, in Produktion moeglichst `false` mit gueltigem Zertifikat.
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_POOL_MIN=0
MSSQL_POOL_MAX=10
MSSQL_CONNECTION_TIMEOUT_MS=15000
MSSQL_REQUEST_TIMEOUT_MS=15000

# Bootstrap
# Fuehrt Knex-Migrationen beim App-Start aus.
APPLY_MIGRATIONS_ON_START=true
# Erstellt Initial-Admin und optionale Grunddaten beim App-Start.
BOOTSTRAP_DATABASE_ON_START=true
# Niemals fuer Produktion aktivieren.
RESET_DATABASE_ON_START=false
# Demo-Nutzer nur fuer Test-/Demo-Umgebungen aktivieren.
ENABLE_DEMO_DATA=false

# Initial Admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
# Fuer lokal nur Beispielwert, spaeter durch starkes Passwort ersetzen.
INITIAL_ADMIN_PASSWORD=change-me-to-a-strong-admin-password
